---
import { ClientRouter } from "astro:transitions";
import "katex/dist/katex.min.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "muhammadakfz",
  description = "Personal website and writing space on physics, projects, and things I am learning in public.",
  image = "/profile.jpeg",
} = Astro.props as Props;

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isBlogIndex = currentPath === "/blog" || currentPath === "/blog/";
const isArticle = currentPath.startsWith("/blog/") && !isBlogIndex;
const siteName = "muhammadakfz";
const canonicalUrl = Astro.site ? new URL(currentPath, Astro.site) : Astro.url;
const socialImageUrl = new URL(image, canonicalUrl);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta name="color-scheme" content="light" />
    <meta name="author" content={siteName} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@200;300;400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=Yellowtail&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="alternate icon" href="/favicon.ico" />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body class="site-shell">
    <a class="skip-link" href="#content">Skip to content</a>

    <details class="menu-drawer" id="site-menu">
      <summary
        class="menu-button"
        aria-label="Toggle menu"
        aria-controls="site-menu-overlay"
        aria-expanded="false"
      >
        <span class="menu-lines" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </summary>

      <div
        class="menu-overlay"
        id="site-menu-overlay"
        role="dialog"
        aria-label="Site menu"
        aria-modal="true"
      >
        <nav class="menu-primary" aria-label="Site links">
          <a class:list={["menu-link", isHome && "is-active"]} href="/" aria-current={isHome ? "page" : undefined}
            >Home</a
          >
          <a
            class="menu-link"
            href="https://github.com/muhammadakfz"
            target="_blank"
            rel="noreferrer noopener"
            >Portfolio</a
          >
          <a
            class:list={["menu-link", (isBlogIndex || isArticle) && "is-active"]}
            href="/blog/"
            aria-current={isBlogIndex || isArticle ? "page" : undefined}
            >Writing</a
          >
        </nav>

        <div class="menu-socials">
          <p>SOCIALS</p>
          <!-- <a href="https://www.youtube.com/" target="_blank" rel="noreferrer noopener">YouTube</a> -->
          <a href="https://www.instagram.com/muhammadakfz" target="_blank" rel="noreferrer noopener"
            >Instagram</a
          >
          <a href="https://www.linkedin.com/in/muhammadakfz" target="_blank" rel="noreferrer noopener"
            >LinkedIn</a
          >
        </div>
      </div>
    </details>

    <script is:inline>
      (() => {
        const setupMenuInteractions = () => {
          if (typeof window === "undefined") return;

          const cleanupKey = "__siteMenuCleanup";
          const previousCleanup = window[cleanupKey];
          if (typeof previousCleanup === "function") {
            previousCleanup();
          }
          window[cleanupKey] = undefined;

          const menu = document.getElementById("site-menu");
          if (!(menu instanceof HTMLDetailsElement)) return;

          const menuButton = menu.querySelector(".menu-button");
          const menuOverlay = menu.querySelector(".menu-overlay");
          const body = document.body;
          const focusableSelector =
            'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';
          let previousFocus = null;

          const syncMenuState = () => {
            body.classList.toggle("has-open-menu", menu.open);
            if (menuButton instanceof HTMLElement) {
              menuButton.setAttribute("aria-expanded", String(menu.open));
            }
          };

          const closeMenu = ({ returnFocus = true } = {}) => {
            if (!menu.open) return;
            menu.open = false;
            syncMenuState();
            if (returnFocus && menuButton instanceof HTMLElement) {
              menuButton.focus();
            }
          };

          const onEscape = (event) => {
            if (event.key !== "Escape" || !menu.open) return;
            closeMenu();
          };

          const onMenuClick = (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            if (menuOverlay instanceof HTMLElement && target === menuOverlay) {
              closeMenu();
              return;
            }

            const clickedLink = target.closest("a");
            if (!clickedLink) return;

            closeMenu({ returnFocus: false });
          };

          const onTabKey = (event) => {
            if (event.key !== "Tab" || !menu.open || !(menuOverlay instanceof HTMLElement)) return;

            const focusables = [...menuOverlay.querySelectorAll(focusableSelector)].filter((element) => {
              if (!(element instanceof HTMLElement)) return false;
              return !element.hasAttribute("disabled");
            });

            if (!focusables.length) return;

            const first = focusables[0];
            const last = focusables[focusables.length - 1];
            const activeElement = document.activeElement;

            if (event.shiftKey) {
              if (activeElement === first || activeElement === menuButton) {
                event.preventDefault();
                last.focus();
              }
              return;
            }

            if (activeElement === last) {
              event.preventDefault();
              first.focus();
            }
          };

          const onToggle = () => {
            if (menu.open) {
              previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
              const firstLink = menu.querySelector(".menu-link");
              if (firstLink instanceof HTMLElement) {
                firstLink.focus();
              }
            } else if (previousFocus instanceof HTMLElement && document.activeElement === document.body) {
              previousFocus.focus();
            }

            syncMenuState();
          };

          window.addEventListener("keydown", onEscape);
          window.addEventListener("keydown", onTabKey);
          menu.addEventListener("click", onMenuClick);
          menu.addEventListener("toggle", onToggle);
          syncMenuState();

          window[cleanupKey] = () => {
            window.removeEventListener("keydown", onEscape);
            window.removeEventListener("keydown", onTabKey);
            menu.removeEventListener("click", onMenuClick);
            menu.removeEventListener("toggle", onToggle);
            body.classList.remove("has-open-menu");
            previousFocus = null;
          };
        };

        setupMenuInteractions();

        const pageLoadListenerKey = "__siteMenuPageLoadListenerAttached";
        if (!window[pageLoadListenerKey]) {
          document.addEventListener("astro:page-load", setupMenuInteractions);
          window[pageLoadListenerKey] = true;
        }
      })();
    </script>

    <main
      id="content"
      class:list={["site-main", isHome && "is-home", isBlogIndex && "is-blog", isArticle && "is-article"]}
    >
      <slot />
    </main>

  </body>
</html>

---
import BaseLayout from "../layout/BaseLayout.astro";
---

<BaseLayout
	title="muhammadakfz | Home"
	description="Builder and writer documenting product lessons, experiments, and execution frameworks."
>
	<section class="home-profile" aria-label="Profile hero">
		<img
			class="profile-photo"
			src="/profile.jpeg"
			alt="Portrait of muhammadakfz"
			width="148"
			height="148"
			loading="eager"
			decoding="async"
			fetchpriority="high"
		/>

		<div class="profile-copy">
			<h1 class="profile-name yellowtail-regular">muhammadakfz</h1>
			<p class="profile-line">Undergraduate Physics Student at University of Indonesia.</p>

			<div class="profile-actions" aria-label="Primary actions">
				<a class="profile-action is-primary" href="/blog/">Read Writing</a>
				<a class="profile-action" href="https://www.linkedin.com/in/muhammadakfz" target="_blank" rel="noreferrer noopener"
					>LinkedIn</a
				>
				<a class="profile-action" href="https://www.instagram.com/muhammadakfz" target="_blank" rel="noreferrer noopener"
					>Instagram</a>
			</div>

		</div>
	</section>
</BaseLayout>
